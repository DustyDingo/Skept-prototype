# Skept Prototype — Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace API token — get one free at https://huggingface.co/settings/tokens
# Without this, frame-level deepfake analysis is skipped (metadata forensics still runs)
HF_TOKEN=hf_your_token_here

# Number of frames to sample per clip (default: 6)
# Higher = more accurate but slower and more API calls
SKEPT_FRAMES=6
